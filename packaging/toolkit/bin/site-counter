#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
export PYTHONPATH="${TOOLKIT_ROOT}/python${PYTHONPATH:+:${PYTHONPATH}}"
export PATH="${TOOLKIT_ROOT}/bin:${PATH}"
export SITE_COUNTER_RS="${SITE_COUNTER_RS:-${TOOLKIT_ROOT}/bin/site_counter_rs}"

PY_CMD="${ESL_PSC_PYTHON:-python3}"
exec "${PY_CMD}" -m esl_psc_cli.fast_scan_cli "$@"
